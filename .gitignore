# Build and Development Artifacts
bin/
obj/
*.dll
*.pdb
*.exe
output/

# Bicep compiled ARM templates
.iac/*.json

# .NET
*.user
*.suo
*.cache
*.nupkg
packages/

# IDE
.vs/
.idea/
*.swp
*.swo
*~

# Azure Functions
local.settings.json

# Assessment output (generated during codespace sessions)
assessment-output/

# Stack inventory artifacts — tracked for retrospective/milestone traceability.
# These capture Azure resource group and Cloudflare DNS state at each blue/green
# swap, documenting environment evolution across phases.
# Only purge artifacts (pre-delete snapshots) are excluded.
artifacts/purge-*.json

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.log

# Resume artifacts — ephemeral workspace (contains PII, not for public repo)
# Binary resumes, generated PDFs, application guides, and job input files
# are created at runtime by the resume-tailoring skill and should not be committed.
# Use tmp/* (not tmp/) so that individual file exceptions can override.
tmp/*
!tmp/.gitkeep
!tmp/job-input.md
